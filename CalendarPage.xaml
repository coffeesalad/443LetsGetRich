<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:BudgetCalendarApp.ViewModels;assembly=BudgetCalendarApp"
    x:Class="BudgetCalendarApp.Views.CalendarPage"
    Title="Budget Calendar">

    <ContentPage.BindingContext>
        <viewmodels:CalendarViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- Date -->
            <Label Text="Select Date" FontAttributes="Bold"/>
            <DatePicker Date="{Binding SelectedDate}" />

            <!-- Add Category -->
            <Label Text="Add New Category" FontAttributes="Bold"/>
            <Entry Placeholder="Category Name"
                   Text="{Binding NewCategoryName}" />
            <Entry Placeholder="Monthly Limit"
                   Keyboard="Numeric"
                   Text="{Binding NewCategoryLimit}" />
            <Button Text="Add Category"
                    Command="{Binding AddCategoryCommand}" />

            <!-- Manage Categories -->
            <Label Text="Manage Categories"
                   FontAttributes="Bold"
                   FontSize="16"/>

            <CollectionView ItemsSource="{Binding Categories}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="*,Auto" Padding="5">

                            <Label Text="{Binding Name}"
                                   VerticalOptions="Center"/>

                            <Button Grid.Column="1"
                                    Text="Delete"
                                    BackgroundColor="Red"
                                    TextColor="White"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteCategoryCommand}"
                                    CommandParameter="{Binding .}" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Select Category -->
            <Label Text="Select Category" FontAttributes="Bold"/>
            <Picker ItemsSource="{Binding Categories}"
                    ItemDisplayBinding="{Binding Name}"
                    SelectedItem="{Binding SelectedCategory}" />

            <!-- Add Entry -->
            <Entry Placeholder="Amount"
                   Keyboard="Numeric"
                   Text="{Binding Amount}" />
            <Button Text="Add Entry"
                    Command="{Binding AddEntryCommand}" />

            <!-- Monthly Total -->
            <Label Text="{Binding MonthlyTotal, StringFormat='Monthly Total: {0:C}'}"
                   FontAttributes="Bold"
                   FontSize="18"/>

            <!-- Category Budget Graph -->
            <Label Text="Category Budget Limits"
                   FontAttributes="Bold"
                   FontSize="16"/>

            <CollectionView ItemsSource="{Binding CategorySummaries}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <VerticalStackLayout Spacing="5" Margin="0,10">

                            <Label Text="{Binding Name}"
                                   FontAttributes="Bold"/>

                            <ProgressBar Progress="{Binding Progress}"
                                         ProgressColor="Green"
                                         BackgroundColor="#EEEEEE"
                                         HeightRequest="10"/>

                            <Label Text="{Binding DisplayText}"
                                   FontSize="12"/>

                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>